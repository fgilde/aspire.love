<ui:FluentWindow x:Class="AspireLove.Studio.AboutWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="About aspire.love"
                 Icon="pack://application:,,,/Assets/aspire.love.ico"
                 Width="440" Height="420"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="" />

        <StackPanel Grid.Row="1" Margin="28,8,28,24">
            <!-- Brand wordmark with the website's pink→purple→indigo gradient. -->
            <TextBlock FontSize="34" FontWeight="Bold"
                       Foreground="{StaticResource BrandGradientBrush}">
                <Run Text="aspire" />
                <Run Text="&#x2665;" />
                <Run Text="love" />
            </TextBlock>
            <TextBlock Text="Studio" FontSize="16" FontWeight="SemiBold" Opacity="0.75" Margin="0,0,0,2" />
            <TextBlock x:Name="VersionText" Opacity="0.6" Margin="0,0,0,16" />

            <TextBlock Text="Make your Lovable project independent. Generate a .NET Aspire AppHost that runs Supabase and your frontend locally."
                       TextWrapping="Wrap" Opacity="0.8" Margin="0,0,0,18" />

            <!-- Update check -->
            <ui:Button x:Name="UpdateButton" Content="Check for updates"
                       Appearance="Primary" Click="OnCheckForUpdates"
                       HorizontalAlignment="Left" />
            <TextBlock x:Name="UpdateStatus" TextWrapping="Wrap" Opacity="0.8"
                       Margin="0,10,0,0" Visibility="Collapsed" />

            <Separator Margin="0,18,0,16" Opacity="0.3" />

            <!-- Links -->
            <StackPanel Orientation="Horizontal">
                <ui:Button Content="GitHub" Click="OnOpenGitHub" Margin="0,0,10,0"
                           Icon="{ui:SymbolIcon Code24}" />
                <ui:Button Content="aspire.love" Click="OnOpenWebsite"
                           Icon="{ui:SymbolIcon Globe24}" />
            </StackPanel>

            <TextBlock Text="MIT © Florian Gilde" Opacity="0.5" FontSize="11" Margin="0,16,0,0" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
