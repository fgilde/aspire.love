<ui:FluentWindow x:Class="AspireLove.Studio.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:AspireLove.Studio.ViewModels"
                 mc:Ignorable="d"
                 Title="aspire.love"
                 Icon="pack://application:,,,/Assets/aspire.love.ico"
                 Width="1100" Height="760"
                 MinWidth="900" MinHeight="600"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Mirrors the website brand mark: "aspire" + gradient heart + "love". -->
                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center"
                               FontSize="14" FontWeight="Bold">
                        <Run Text="aspire" />
                        <Run Text="&#x2665;" Foreground="{StaticResource BrandPinkBrush}" />
                        <Run Text="love" />
                    </TextBlock>
                    <ui:Button Margin="8,0,0,0" Padding="6" Appearance="Transparent"
                               Icon="{ui:SymbolIcon Info24}" Click="OnShowAbout"
                               ToolTip="About aspire.love — version, updates &amp; links" />
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="20,8,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ============================ Form ============================ -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                <StackPanel>
                    <!-- Brand wordmark with the website's pink→purple→indigo gradient. -->
                    <TextBlock FontSize="30" FontWeight="Bold" Margin="0,0,0,2"
                               Foreground="{StaticResource BrandGradientBrush}">
                        <Run Text="aspire" />
                        <Run Text="&#x2665;" />
                        <Run Text="love" />
                    </TextBlock>
                    <TextBlock Text="Make your Lovable project independent"
                               FontSize="20" FontWeight="SemiBold" Margin="0,0,0,2" />
                    <TextBlock Text="Generate a .NET Aspire AppHost that runs Supabase + your frontend locally."
                               Opacity="0.7" Margin="0,0,0,16" TextWrapping="Wrap" />

                    <!-- Project location -->
                    <ui:Card Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Lovable project folder" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBox Grid.Column="0"
                                            PlaceholderText="C:\path\to\your\lovable\project"
                                            Text="{Binding LovableProjectPath, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseCommand}" />
                            </Grid>
                        </StackPanel>
                    </ui:Card>

                    <!-- Identity -->
                    <ui:Card Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Project identity" FontWeight="SemiBold" Margin="0,0,0,8" />

                            <TextBlock Text="Project name (optional — defaults to package.json)" Opacity="0.7" Margin="0,0,0,2" />
                            <ui:TextBox PlaceholderText="MyAspireLove"
                                        Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding ResolvedNameHint}" Opacity="0.6" FontSize="11" Margin="2,4,0,0" />

                            <TextBlock Text="Organization name" Opacity="0.7" Margin="0,10,0,2" />
                            <ui:TextBox Text="{Binding OrganizationName, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </ui:Card>

                    <!-- Default user -->
                    <ui:Card Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Default user (seeded into Supabase / Studio)" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Name" Opacity="0.7" Margin="0,0,0,2" />
                                    <ui:TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Password" Opacity="0.7" Margin="0,0,0,2" />
                                    <ui:TextBox Text="{Binding UserPassword, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Email" Opacity="0.7" Margin="0,8,0,2" />
                            <ui:TextBox Text="{Binding UserEmail, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </ui:Card>

                    <!-- Mode -->
                    <ui:Card Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Mode" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <ComboBox ItemsSource="{Binding Modes}"
                                      SelectedItem="{Binding Mode}"
                                      HorizontalAlignment="Stretch" />
                            <TextBlock Text="{Binding ModeDescription}" Opacity="0.7"
                                       TextWrapping="Wrap" Margin="2,8,0,0" />

                            <!-- Sync credentials -->
                            <StackPanel Margin="0,10,0,0"
                                        Visibility="{Binding IsSyncMode, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Project Ref" Opacity="0.7" Margin="0,0,0,2" />
                                <ui:TextBox Text="{Binding SyncProjectRef, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Service Key" Opacity="0.7" Margin="0,8,0,2" />
                                <ui:TextBox Text="{Binding SyncServiceKey, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Database Password" Opacity="0.7" Margin="0,8,0,2" />
                                <ui:TextBox Text="{Binding SyncDbPassword, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Management Token" Opacity="0.7" Margin="0,8,0,2" />
                                <ui:TextBox Text="{Binding SyncManagementToken, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <!-- Remote credentials -->
                            <StackPanel Margin="0,10,0,0"
                                        Visibility="{Binding IsRemoteMode, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Project Ref" Opacity="0.7" Margin="0,0,0,2" />
                                <ui:TextBox Text="{Binding RemoteProjectRef, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Service Key" Opacity="0.7" Margin="0,8,0,2" />
                                <ui:TextBox Text="{Binding RemoteServiceKey, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>
                    </ui:Card>

                    <!-- Options -->
                    <ui:Card Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Options" FontWeight="SemiBold" Margin="0,0,0,8" />

                            <ui:ToggleSwitch Content="Add observability (Grafana / Tempo / OTel)"
                                             IsChecked="{Binding AddMonitoring}"
                                             IsEnabled="{Binding UsesLocalSupabase}" Margin="0,0,0,8" />

                            <TextBlock Text="Database password (local Postgres)"
                                       Opacity="0.7" Margin="0,0,0,2"
                                       Visibility="{Binding UsesLocalSupabase, Converter={StaticResource BoolToVisibility}}" />
                            <ui:TextBox Text="{Binding DatabasePassword, UpdateSourceTrigger=PropertyChanged}"
                                        Visibility="{Binding UsesLocalSupabase, Converter={StaticResource BoolToVisibility}}" />

                            <TextBlock Text="LOVABLE_API_KEY (optional — keeps Lovable's built-in AI working locally)"
                                       Opacity="0.7" Margin="0,10,0,2" TextWrapping="Wrap" />
                            <ui:TextBox Text="{Binding LovableApiKey, UpdateSourceTrigger=PropertyChanged}" />

                            <ui:ToggleSwitch Content="Dry run (preview only — write nothing to disk)"
                                             IsChecked="{Binding DryRun}" Margin="0,12,0,0" />
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </ScrollViewer>

            <!-- ====================== Validation + Preview ====================== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ui:InfoBar Grid.Row="0" Margin="0,0,0,12"
                            IsOpen="True"
                            Title="Validation"
                            Message="{Binding ValidationSummary}"
                            Severity="Informational" />

                <ui:Card Grid.Row="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="AppHost.cs preview — updates live as you type"
                                   FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding PreviewContent, Mode=OneWay}"
                                     IsReadOnly="True" BorderThickness="0"
                                     Background="Transparent"
                                     FontFamily="Cascadia Code, Consolas, monospace"
                                     FontSize="12"
                                     TextWrapping="NoWrap"
                                     VerticalAlignment="Top" />
                        </ScrollViewer>
                    </Grid>
                </ui:Card>
            </Grid>
        </Grid>

        <!-- ============================ Footer ============================ -->
        <Border Grid.Row="2" Padding="20,12" Margin="0,8,0,0"
                Background="{DynamicResource ApplicationBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Opacity="0.85" />
                    <TextBlock Text="{Binding AspireProjectStatus}" TextWrapping="Wrap"
                               Opacity="0.55" FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button Content="Launch"
                               Command="{Binding LaunchCommand}" Margin="0,0,8,0"
                               ToolTip="Run 'dotnet run' on the generated AppHost in a new terminal." />
                    <ui:Button Content="Publish"
                               Command="{Binding PublishCommand}" Margin="0,0,8,0"
                               ToolTip="Run 'azd up' in a new terminal to deploy to Azure." />
                    <ui:Button Content="Generate" Appearance="Primary" Command="{Binding GenerateCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
